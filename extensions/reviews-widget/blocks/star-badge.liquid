{% comment %}
  ============================================================
  App Block 1 — Product Title Star Badge
  File: /extensions/reviews-widget/blocks/star-badge.liquid
  Placement: directly under the product title.
  ============================================================
{% endcomment %}

{%- assign product_id = product.id | default: 'demo' -%}
{%- assign product_handle = product.handle | default: 'demo' -%}
{%- assign shop_domain = shop.permanent_domain -%}
{%- assign api_base = block.settings.api_base | default: 'https://review-lovely-lady.vercel.app' -%}

<div
  class="evo-star-badge"
  data-evo-star-badge
  data-shop="{{ shop_domain }}"
  data-product-id="{{ product_id }}"
  data-product-handle="{{ product_handle }}"
  data-api="{{ api_base }}"
>
  <div class="evo-sb__row">
    <span class="evo-sb__star" aria-hidden="true">
      <!-- gold star -->
      <svg viewBox="0 0 24 24" width="18" height="18">
        <path d="M12 2.5l2.95 6.4 7.05.7-5.3 4.85 1.55 6.95L12 17.9l-6.25 3.5L7.3 14.45 2 9.6l7.05-.7L12 2.5z"
              fill="#FFC107"/>
      </svg>
    </span>

    <span class="evo-sb__avg" data-evo-avg>—</span>

    <span class="evo-sb__divider" aria-hidden="true">|</span>

    <span class="evo-sb__verified" aria-hidden="true">
      <!-- blue verified seal -->
      <svg viewBox="0 0 18 18" width="18" height="18">
        <polygon fill="#005eff" points="9,16 7.1,16.9 5.8,15.2 3.7,15.1 3.4,13 1.5,12 2.2,9.9 1.1,8.2 2.6,6.7 2.4,4.6 4.5,4 5.3,2 7.4,2.4 9,1.1 10.7,2.4 12.7,2 13.6,4 15.6,4.6 15.5,6.7 17,8.2 15.9,9.9 16.5,12 14.7,13 14.3,15.1 12.2,15.2 10.9,16.9"/>
        <path d="M5.7 9.1 L7.8 11.2 L12.2 6.7" fill="none" stroke="#ffffff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>

    <span class="evo-sb__count" data-evo-count>(0 Reviews)</span>
  </div>
</div>

<style>
  .evo-star-badge{
    font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, sans-serif;
    color:#111;
    margin: 6px 0 12px;
    line-height:1.2;
  }
  .evo-sb__row{
    display:inline-flex;
    align-items:center;
    gap:8px;
    flex-wrap:wrap;
  }
  .evo-sb__star{ display:inline-flex; }
  .evo-sb__avg{
    font-weight:700;
    font-size:15px;
    color:#111;
  }
  .evo-sb__divider{
    color:#D1D5DB;
    font-weight:300;
    margin:0 2px;
  }
  .evo-sb__verified{ display:inline-flex; }
  .evo-sb__count{
    font-weight:500;
    font-size:15px;
    color:#111827;            /* dark review count — matches reference */
  }
  .evo-sb__viewers{
    display:inline-flex;
    align-items:center;
    gap:6px;
    margin-top:6px;
    font-size:12.5px;
    color:#6B7280;
  }
  .evo-sb__eye{ display:inline-flex; }
  [data-evo-viewers]{ font-weight:600; color:#374151; }
</style>

<script>
  (function () {
    var root = document.querySelector('[data-evo-star-badge]');
    if (!root || root.__evoInit) return;
    root.__evoInit = true;

    var shop          = root.dataset.shop;
    var productId     = root.dataset.productId;
    var productHandle = root.dataset.productHandle;
    var apiBase       = (root.dataset.api || '').replace(/\/$/, '');
    var avgEl         = root.querySelector('[data-evo-avg]');
    var countEl       = root.querySelector('[data-evo-count]');
    var viewersEl     = root.querySelector('[data-evo-viewers]');

    function fmtCount(n) {
      n = Number(n) || 0;
      if (n < 1000) return String(n);
      if (n < 10000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
      if (n < 1000000) return Math.floor(n / 1000) + 'K';
      return (n / 1000000).toFixed(1).replace(/\.0$/, '') + 'M';
    }

    // ---- Live aggregate ----
    if (apiBase && shop && (productId || productHandle)) {
      fetch(apiBase + '/api/reviews?shop=' + encodeURIComponent(shop)
           + (productHandle ? '&productHandle=' + encodeURIComponent(productHandle) : '')
           + (productId ? '&productId=' + encodeURIComponent(productId) : '')
           + '&page=1&limit=1')
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (avgEl)   avgEl.textContent   = (d.average || 0).toFixed(1);
          if (countEl) countEl.textContent = '(' + fmtCount(d.totalRatings || 0) + ' Reviews)';
        })
        .catch(function () { /* fail silently on storefront */ });
    }

  })();
</script>

{% schema %}
{
  "name": "Star Badge",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_base",
      "label": "App API base URL",
      "default": "https://review-lovely-lady.vercel.app",
      "info": "The Vercel URL where the Remix app is deployed."
    }
  ]
}
{% endschema %}
